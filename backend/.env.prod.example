DJANGO_SECRET_KEY=replace-with-strong-secret
DEBUG=0
ALLOWED_HOSTS=potatofarm.ru,www.potatofarm.ru
CSRF_TRUSTED_ORIGINS=https://potatofarm.ru,https://www.potatofarm.ru

POSTGRES_DB=shop
POSTGRES_USER=shop
POSTGRES_PASSWORD=replace-db-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CACHE_BACKEND=redis
CACHE_URL=redis://redis:6379/1
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=bgshop
CACHE_TTL_HEADER_CATEGORIES=900
CACHE_TTL_HOME=180
CACHE_TTL_CATALOG_FILTERS=900
CACHE_TTL_LIVE_SEARCH=60
CACHE_TTL_ES_SEARCH=120
CACHE_TTL_CATALOG_API=120
CACHE_TTL_COMMERCE_LOOKUPS=600

MEDIA_ROOT=/app/media

# App integrations
INTERNAL_TOKEN=replace-internal-token
ORDER_APPROVE_SECRET=replace-order-secret
METRICS_TOKEN=replace-metrics-token
BOT_BASE_URL=http://bot:8080
BOT_TWA_URL=http://bot-twa:8080
BOT_NOTIFY_URL=http://bot-notify:8080

# Telegram
TELEGRAM_BOT_TOKEN=replace-main-bot-token
TG_INIT_DATA_MAX_AGE_SECONDS=300
ADMIN_NOTIFY_TELEGRAM_IDS=

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email SMTP
ADMIN_NOTIFY_EMAILS=admin@potatofarm.ru
DEFAULT_FROM_EMAIL=noreply@potatofarm.ru
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
EMAIL_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
LOG_JSON=1
DB_LOG_LEVEL=WARNING
ENABLE_REQUEST_ACCESS_LOG=1
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
