      "type": "timeseries",
      "title": "PostgreSQL Connections",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count)",
          "legendFormat": "connections"
        }
      ]
