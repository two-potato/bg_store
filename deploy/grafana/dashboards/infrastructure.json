{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Host CPU Usage %",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{instance}}"}
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Host Memory Used %",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "{{instance}}"}
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Container CPU (cAdvisor)",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"bg-.*\"}[5m]))", "legendFormat": "{{name}}"}
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Container Memory (cAdvisor)",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (name) (container_memory_working_set_bytes{name=~\"bg-.*\"})", "legendFormat": "{{name}}"}
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Nginx Request Rate",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(nginx_http_requests_total[5m])) by (status)", "legendFormat": "{{status}}"}
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Nginx Connections",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(nginx_connections_active)", "legendFormat": "active"},
        {"expr": "sum(nginx_connections_reading)", "legendFormat": "reading"},
        {"expr": "sum(nginx_connections_writing)", "legendFormat": "writing"},
        {"expr": "sum(nginx_connections_waiting)", "legendFormat": "waiting"}
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["infra", "node", "nginx", "cadvisor"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "Infrastructure",
  "uid": "bg-infra",
  "version": 1
}
