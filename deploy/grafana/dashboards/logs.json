  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log Lines Rate by Service",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "sum by (service) (rate({service=~\".+\"}[5m]))", "legendFormat": "{{service}}"}
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate by Service",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"expr": "sum by (service) (rate({service=~\".+\"} |= \"ERROR\" [5m]))", "legendFormat": "{{service}}"}
      ]
    },
    {
      "id": 3,
      "type": "logs",
      "title": "All Services Logs",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 12},
